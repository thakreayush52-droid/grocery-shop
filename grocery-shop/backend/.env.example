# Backend Port
PORT=5000

# MongoDB Connection (Replace with your MongoDB Atlas URI for production)
# Example: mongodb+srv://username:password@cluster.mongodb.net/grocery_shop?retryWrites=true&w=majority
MONGODB_URI=mongodb://localhost:27017/grocery_shop

# JWT Secret Key (Change this to a strong random string in production!)
JWT_SECRET=grocery_shop_secret_key_2024

# ML Service URL
ML_SERVICE_URL=http://localhost:5001

# Cloudinary Configuration (Get these from https://cloudinary.com)
CLOUDINARY_CLOUD_NAME=your-cloud-name-here
CLOUDINARY_API_KEY=your-api-key-here
CLOUDINARY_API_SECRET=your-api-secret-here

# Auto-seed database on startup (set to true for first deployment, then false)
AUTO_SEED=false

# Frontend URL (for CORS)
FRONTEND_URL=http://localhost:5173
